{
	"name": "mattermost-cli",
	"version": "1.0.0",
	"description": "Read-only Mattermost context retrieval and indexing.",
	"type": "module",
	"private": true,
	"packageManager": "bun@1.3.3",
	"module": "./src/index.ts",
	"exports": {
		".": "./src/index.ts"
	},
	"bin": {
		"mm": "./src/cli/bin.ts"
	},
	"scripts": {
		"start": "bun run src/cli/bin.ts",
		"dev": "bun --watch src/cli/bin.ts",
		"typecheck": "tsc --noEmit",
		"lint": "biome lint .",
		"lint:fix": "biome lint --write .",
		"format": "biome format .",
		"format:fix": "biome format --write .",
		"test": "bun test",
		"benchmark": "bun run src/benchmark/benchmark-cli.ts benchmarks/retrieval.v1.json",
		"benchmark:compare": "bun run src/benchmark/benchmark-compare-cli.ts",
		"smoke": "MATTERMOST_INTEGRATION=1 bun test src/mattermost/integration.test.ts",
		"check": "bun run typecheck && biome check . && bun test",
		"check:release": "bun run check && bun run smoke",
		"check:fix": "biome check --write ."
	},
	"dependencies": {
		"chalk": "5.6.2",
		"commander": "15.0.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@types/bun": "latest",
		"typescript": "6.0.3"
	}
}
